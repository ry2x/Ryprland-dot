[Desktop Entry]
Name=Obsidian
Exec=/usr/bin/obsidian --password-store=gnome-libsecret --enable-wayland-ime --enable-features=UseOzonePlatform --ozone-platform=wayland %U
Terminal=false
Type=Application
Icon=obsidian
StartupWMClass=obsidian
Comment=Obsidian
MimeType=x-scheme-handler/obsidian;
Categories=Office;
